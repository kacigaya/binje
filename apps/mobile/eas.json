{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://binje-stream.netlify.app",
        "EXPO_PUBLIC_RESOLVE_BASE_URL": "https://binje-stream.sparkling-limit-e94a.workers.dev"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://binje-stream.netlify.app",
        "EXPO_PUBLIC_RESOLVE_BASE_URL": "https://binje-stream.sparkling-limit-e94a.workers.dev"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
